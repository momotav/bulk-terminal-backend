# Postgres (internal)
POSTGRES_PASSWORD=change-me-long-random
DATABASE_URL=postgresql://bulkstats:change-me-long-random@db:5432/bulkstats
# leave DATABASE_SSL unset for local Postgres (see Step 5)

# app
NODE_ENV=production
PORT=3001
FRONTEND_URL=https://bulkstats.com
JWT_SECRET=another-long-random-secret

# Redis intentionally unset -> app uses in-memory cache fallback
# REDIS_URL=

# BULK upstream (networks themselves live in services/networks.ts, NOT here)
BULK_API_KEY=            # rotate
BULK_API_URL=https://exchange-api.bulk.trade/api/v1
BULK_WS_URL=wss://exchange-ws1.bulk.trade
BULK_EXPLORER_HTTP_URL=
BULK_EXPLORER_WS_URL=

# Solana (powers all on-chain indexers)
SOLANA_RPC_URL=          # Helius — rotate

# Privy
PRIVY_APP_ID=
PRIVY_APP_SECRET=
PRIVY_VERIFICATION_KEY=

# reset token — generate with: openssl rand -hex 32
# Publicly reachable endpoint; a guessable value lets anyone wipe your backfills.
PREDEPOSIT_RESET_TOKEN=
